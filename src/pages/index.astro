---
import type {ComponentProps} from 'astro/types';
import BaseLayout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Massages from '../components/Massages.astro';
import About from '../components/About.astro';
import Booking from '../components/Booking.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import {site} from '../data/site';

type HeroProps = ComponentProps<typeof Hero>;
type ContactProps = ComponentProps<typeof Contact>;

const heroProps = {
  subtitle: site.subtitle,
  bookingUrl: site.bookingUrl,
  phoneHref: site.phoneHref,
  ...site.hero,
} satisfies HeroProps;

const contactProps = {
  phoneDisplay: site.phoneDisplay,
  phoneHref: site.phoneHref,
  email: site.email,
  locationText: site.locationText,
} satisfies ContactProps;
---

<BaseLayout
  title={`${site.brand} | Massage bien-être à Annecy`}
  description="Massages bien-être à Annecy. Réservation en ligne."
>
  <Header brand={site.brand} />

  <main>
    <Hero {...heroProps} />

    <Massages items={site.massages} />

    <About {...site.about} />

    <Booking bookingUrl={site.bookingUrl} />

    <Contact {...contactProps} />
  </main>

  <Footer brand={site.brand} />
</BaseLayout>
