---
import type {SiteData} from '../data/site';
import SectionIntro from './SectionIntro.astro';

type Props = SiteData['testimonials'];

const {title, intro, items} = Astro.props;
---

<section id="avis-clientes" class="section-pad bg-surface-muted">
  <div class="container-page">
    <SectionIntro title={title} text={intro} />

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        items.map((item) => (
          <article class="card-soft flex h-full flex-col p-6 sm:p-7">
            <div
              class="mb-4 text-xs font-semibold tracking-[0.28em] text-accent-strong/80 uppercase"
              aria-hidden="true"
            >
              ★★★★★
            </div>

            <p class="mt-1 text-lg leading-relaxed text-ink">
              “{item.text}”
            </p>

            <p class="mt-6 text-sm font-medium text-ink/68">{item.author}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
